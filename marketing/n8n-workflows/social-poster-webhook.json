    {
      "parameters": {
        "jsCode": "// Validate incoming webhook data\nconst body = $input.first().json.body || $input.first().json;\n\nconst content = body.content || body.message || body.text;\nconst platforms = body.platforms || ['x', 'linkedin', 'facebook'];\nconst hashtags = body.hashtags || '';\n\nif (!content) {\n  return [{ json: { error: 'Missing content field in request body' } }];\n}\n\nconst fullContent = hashtags ? content + '\\n\\n' + hashtags : content;\n\nreturn [{\n  json: {\n    content: fullContent,\n    contentShort: fullContent.substring(0, 280),\n    platforms: platforms,\n    postToX: platforms.includes('x'),\n    postToLinkedIn: platforms.includes('linkedin'),\n    postToFacebook: platforms.includes('facebook'),\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "parse-input",
      "name": "Parse Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [{ "id": "c1", "leftValue": "={{ $json.postToX }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }],
          "combinator": "and"
        }
      },
      "id": "if-x",
      "name": "X?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [700, 200]
    },
    {
